API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_URL=http://localhost:5173
USE_LOCAL_MODEL=True
# Ollama (local LLM) settings
OLLAMA_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3:latest

# OpenAI (optional) settings - leave blank to prefer local model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DEVICE=cuda

DATABASE_URL=sqlite:///./database/conversations.db
# Notes:
# - Set USE_LOCAL_MODEL=True to prefer Ollama/local LLMs. Set to False to prefer OpenAI when API key is present.
# - Ensure Ollama is running (ollama serve) and the model specified in LOCAL_LLM_MODEL is available.
